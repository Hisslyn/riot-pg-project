# Riot Games API Key (get yours at https://developer.riotgames.com/)
RIOT_API_KEY=RGAPI-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# PostgreSQL connection string
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/riot_data

# Riot account credentials — used by scripts/refresh_api_key.py to auto-rotate the dev key
RIOT_USERNAME=your@email.com
RIOT_PASSWORD=yourpassword
